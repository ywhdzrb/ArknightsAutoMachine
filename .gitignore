# ============================================
# Arknights Auto Machine - Git Ignore
# ============================================

# ==================== Python ====================
# 字节码文件
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ==================== 日志文件 ====================
# 应用程序日志
logs/
*.log
*.log.*

# ==================== 配置文件 ====================
# 用户特定配置（包含敏感信息）
config/user_settings.json
config/*.local.json
*.local.yaml
*.local.yml
*.local.conf

# ==================== 虚拟环境 ====================
# Python 虚拟环境
venv/
venv*/
env/
ENV/
.venv/
.conda/

# ==================== IDE / 编辑器 ====================
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#

# ==================== 操作系统 ====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.nfs*

# ==================== 测试 / 覆盖率 ====================
# 测试输出
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ==================== 临时文件 ====================
# 临时目录
temp/
tmp/
*.tmp
*.temp
*.bak
*.backup

# 截图临时文件
screenshots/temp/

# ==================== 数据文件 ====================
# 模型文件（大文件，建议用 Git LFS 或单独管理）
models/*.pt
models/*.pth
models/*.onnx
models/*.tflite
models/*.h5
models/*.pb
models/*.ckpt
models/*.safetensors

# 数据集
data/raw/
data/processed/
*.csv
*.tsv
*.jsonl

# ==================== 文档生成 ====================
# 生成的文档
docs/_build/
docs/api/
*.pdf

# ==================== 其他 ====================
# 本地开发文件
.env
.env.local
.env.*.local

# 调试文件
*.debug

# 缓存文件
.cache/
.mypy_cache/
.dmypy.json
.dmypy.json.*/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# 数据库文件
*.db
*.sqlite
*.sqlite3
config/user_settings.json
